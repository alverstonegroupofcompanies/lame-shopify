{% liquid
  assign showcase_collection = collections[section.settings.collection]
  if showcase_collection == blank
    assign showcase_collection = collections.all
  endif

  assign primary_product = showcase_collection.products[0]
  assign secondary_product_1 = showcase_collection.products[1]
  assign secondary_product_2 = showcase_collection.products[2]
%}

<section class="lame-showcase color-{{ section.settings.color_scheme }}">
  <div class="lame-showcase__inner section section--page-width">
    <div class="lame-showcase__left">
      <p class="lame-showcase__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="lame-showcase__heading">
        {{ section.settings.heading }}
      </h2>
      <p class="lame-showcase__text">
        {{ section.settings.description }}
      </p>
      <div class="lame-showcase__cta-row">
        <a class="lame-showcase__button button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
      </div>
      <p class="lame-showcase__footnote">
        {{ section.settings.footnote }}
      </p>
    </div>

    <div class="lame-showcase__right">
      <article class="lame-showcase__card lame-showcase__card--primary">
        {% if primary_product and primary_product.featured_media %}
          {{
            primary_product.featured_media
            | image_url: width: 1200
            | image_tag: loading: 'lazy', class: 'lame-showcase__image', widths: '480, 720, 960, 1200'
          }}
        {% endif %}
        <div class="lame-showcase__overlay">
          <span class="lame-showcase__tag">Lame signature</span>
          <h3 class="lame-showcase__card-title">
            {{ primary_product.title | default: 'Clean beauty essentials for natural glow' }}
          </h3>
        </div>
      </article>

      <div class="lame-showcase__mini-grid">
        <article class="lame-showcase__card lame-showcase__card--mini">
          {% if secondary_product_1 and secondary_product_1.featured_media %}
            {{
              secondary_product_1.featured_media
              | image_url: width: 700
              | image_tag: loading: 'lazy', class: 'lame-showcase__image', widths: '320, 480, 700'
            }}
          {% endif %}
          <div class="lame-showcase__overlay lame-showcase__overlay--mini">
            <h4 class="lame-showcase__mini-title">
              {{ secondary_product_1.title | default: 'Beauty crafted by Lame' }}
            </h4>
          </div>
        </article>

        <article class="lame-showcase__card lame-showcase__card--mini">
          {% if secondary_product_2 and secondary_product_2.featured_media %}
            {{
              secondary_product_2.featured_media
              | image_url: width: 700
              | image_tag: loading: 'lazy', class: 'lame-showcase__image', widths: '320, 480, 700'
            }}
          {% endif %}
          <div class="lame-showcase__overlay lame-showcase__overlay--mini">
            <h4 class="lame-showcase__mini-title">
              {{ secondary_product_2.title | default: 'Targeted care with visible results' }}
            </h4>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .lame-showcase {
    --showcase-accent: 193 151 31;
    --showcase-ink: 18 18 22;
    --showcase-muted: 106 106 116;
    padding: 2.2rem 0 1.5rem;
  }

  .lame-showcase__inner {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(1.2rem, 2.4vw, 2rem);
    align-items: stretch;
  }

  .lame-showcase__left {
    background: linear-gradient(165deg, rgb(255 255 255), rgb(250 248 243));
    border: 1px solid rgb(193 151 31 / 0.2);
    border-radius: 1.1rem;
    padding: clamp(1rem, 2vw, 1.65rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  .lame-showcase__eyebrow {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--showcase-accent));
    font-weight: 600;
  }

  .lame-showcase__heading {
    margin: 0;
    color: rgb(var(--showcase-ink));
    font-size: clamp(1.85rem, 4.6vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  .lame-showcase__heading em {
    color: rgb(var(--showcase-accent));
    font-style: normal;
  }

  .lame-showcase__text {
    margin: 0;
    color: rgb(var(--showcase-muted));
    line-height: 1.6;
    max-width: 42ch;
  }

  .lame-showcase__button.button {
    min-height: 2.3rem;
    border-radius: 999px;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.5rem 0.95rem;
    background: linear-gradient(135deg, rgb(var(--showcase-ink)), rgb(35 35 40));
    border-color: rgb(var(--showcase-ink));
    color: #fff;
  }

  .lame-showcase__button.button:hover {
    opacity: 0.92;
  }

  .lame-showcase__footnote {
    margin: 0.1rem 0 0;
    font-size: 0.83rem;
    color: rgb(var(--showcase-muted));
  }

  .lame-showcase__right {
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 0.8rem;
  }

  .lame-showcase__card {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgb(193 151 31 / 0.23);
    background: rgb(248 246 241);
    min-height: 0;
  }

  .lame-showcase__card--primary {
    min-height: clamp(260px, 42vw, 430px);
  }

  .lame-showcase__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .lame-showcase__overlay {
    position: absolute;
    inset: auto 0 0;
    padding: 0.8rem 0.9rem;
    background: linear-gradient(180deg, transparent, rgb(0 0 0 / 0.62) 72%);
    color: #fff;
  }

  .lame-showcase__tag {
    display: inline-flex;
    margin-bottom: 0.42rem;
    padding: 0.22rem 0.55rem;
    border: 1px solid rgb(255 255 255 / 0.5);
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .lame-showcase__card-title {
    margin: 0;
    font-size: clamp(0.92rem, 1.4vw, 1.08rem);
    line-height: 1.4;
    max-width: 36ch;
  }

  .lame-showcase__mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }

  .lame-showcase__card--mini {
    min-height: clamp(120px, 16vw, 180px);
  }

  .lame-showcase__overlay--mini {
    padding: 0.55rem 0.62rem;
    background: linear-gradient(180deg, transparent, rgb(0 0 0 / 0.68) 78%);
  }

  .lame-showcase__mini-title {
    margin: 0;
    font-size: clamp(0.76rem, 1vw, 0.9rem);
    line-height: 1.35;
  }

  @media screen and (max-width: 989px) {
    .lame-showcase {
      padding: 1.4rem 0 1rem;
    }

    .lame-showcase__inner {
      grid-template-columns: 1fr;
    }

    .lame-showcase__card--primary {
      min-height: clamp(240px, 56vw, 420px);
    }
  }

  @media screen and (max-width: 749px) {
    .lame-showcase__left {
      border-radius: 0.85rem;
      padding: 0.95rem;
    }

    .lame-showcase__heading {
      font-size: clamp(1.5rem, 8.2vw, 2.1rem);
    }

    .lame-showcase__text {
      font-size: 0.92rem;
    }

    .lame-showcase__mini-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.55rem;
    }

    .lame-showcase__card,
    .lame-showcase__card--primary {
      border-radius: 0.8rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lame showcase",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "default": "all"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Lame beauty care"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Reveal Your Natural Glow With <em>Lame Solutions</em>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover clean and effective skincare thoughtfully curated by Lame for radiant skin every day."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Start Shopping"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote",
      "default": "Trusted formulas. Visible glow. Loved by skincare buyers."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Lame showcase"
    }
  ]
}
{% endschema %}
